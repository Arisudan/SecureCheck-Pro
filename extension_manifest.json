{
  "manifest_version": 3,
  "name": "SecureCheck Pro Plugin",
  "short_name": "SecureCheck",
  "version": "1.1.0",
  "description": "High-fidelity security analyzer and training hub.",
  "action": {
    "default_popup": "index.html",
    "default_title": "SecureCheck Pro",
    "default_icon": "icon-192.png"
  },
  "icons": {
    "192": "icon-192.png",
    "512": "icon-512.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
